# ldn_mitm internet-relay servers.
# Copy this to  sdmc:/config/ldn_mitm/relay.cfg  on your SD card.
#
# One server per line:   <name>  <address[:PORT]>
#   - name is a label shown in the Tesla overlay picker
#   - address is an IPv4 literal OR a hostname (resolved via DNS)
#   - default port is 11451 (the lan-play default)
#   - lines starting with '#' and blank lines are ignored
#   - up to 8 servers
#
# Listing servers here does NOT turn the relay on. Open the Tesla overlay,
# toggle "Internet relay" on, and pick a server. Relay off = normal local LDN.
#
# The overlay settings are saved back into this file as directive lines, so
# they survive reboots. You can also preset them here yourself:
#enabled=1          internet relay on at boot
#broadcast=1        bsd broadcast relay (the lag fix; on by default)
#selected=my-pc     which server from the list below is active (by name)

my-pc        82.65.234.243:11455
lan-play     104.238.152.86
public       relay.example.com
